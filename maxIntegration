import { fetchMaxAllPages } from "./maxScraper.js";
import { parseMaxProducts } from "./maxParser.js";

export async function getMaxProducts() {
    const rawHtmlItems = await fetchMaxAllPages();
    const products = parseMaxProducts(rawHtmlItems);

    return products.map(p => ({
        ...p,
        site: "max",
        timestamp: Date.now()
    }));
}
