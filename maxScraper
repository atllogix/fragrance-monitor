import fetch from "node-fetch";

const BASE_URL = "https://www.maxaroma.com/get_products";

async function fetchMaxPage(page = 1) {
    const params = new URLSearchParams({
        new_filter: "1",
        categories: "na",
        brands: "[]",
        sortby: "Sort By",
        page: String(page)
    });

    const url = `${BASE_URL}?${params.toString()}`;

    const res = await fetch(url, {
        method: "GET",
        headers: {
            "Accept": "application/json, text/javascript, */*; q=0.01",
            "X-Requested-With": "XMLHttpRequest"
        }
    });

    if (!res.ok) {
        console.error(`MaxAroma page ${page} failed:`, res.status);
        return { products: [], page, hasMore: false };
    }

    const json = await res.json();

    // ProductHTML is a giant HTML blob containing multiple <li> items
    const html = json.ProductHTML || "";

    // Extract each <li> block
    const items = html
        .split("<li")
        .slice(1)
        .map(x => "<li" + x.split("</li>")[0] + "</li>");

    const total = Number(json.TotalProducts || 0);
    const perPage = items.length;
    const maxPages = Math.ceil(total / perPage);

    return {
        products: items,
        page,
        hasMore: page < maxPages
    };
}

export async function fetchMaxAllPages() {
    let all = [];
    let page = 1;

    while (true) {
        const { products, hasMore } = await fetchMaxPage(page);
        all.push(...products);

        if (!hasMore) break;
        page++;
    }

    return all;
}
